{
  "tests": [
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"login": "nobody", "password": "wrong"},
      "expectedStatus": 401
    },
    {
      "name": "Register with wrong admin key",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "admin_key": "wrong", "login": "test", "full_name": "Test", "role_code": "engineer", "password": "test123"},
      "expectedStatus": 403
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    }
  ]
}