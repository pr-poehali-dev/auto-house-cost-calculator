      "path": "/",
      "body": {"login": "nobody", "password": "wrong"},
      "expectedStatus": 401
    },
    {
      "name": "Register with missing fields",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "login": "", "full_name": "", "role_code": "engineer", "password": ""},
      "expectedStatus": 400
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    }
  ]
}