{
  "tests": [
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"email": "nobody@test.com", "password": "wrong"},
      "expectedStatus": 401
    },
    {
      "name": "RFQ list without token",
      "method": "GET",
      "path": "/?action=rfq_list",
      "expectedStatus": 404
    },
    {
      "name": "Materials search no token",
      "method": "POST",
      "path": "/?action=materials_search",
      "body": {"q": "кирпич"},
      "expectedStatus": 404
    },
    {
      "name": "Price list get no token",
      "method": "GET",
      "path": "/?action=price_list_get",
      "expectedStatus": 404
    },
    {
      "name": "AI classify no token",
      "method": "POST",
      "path": "/?action=ai_classify",
      "body": {"items": [{"material_name": "Кирпич рядовой М150", "unit": "шт", "category": "Прочее"}]},
      "expectedStatus": 404
    },
    {
      "name": "Admin reset password no token",
      "method": "POST",
      "path": "/?action=admin_reset_password",
      "body": {"email": "test@test.com", "password": "test"},
      "expectedStatus": 403
    }
  ]
}